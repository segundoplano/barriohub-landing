---
import Nav from "../components/Navbar.astro";
import "/public/scripts/menu.js";
import "/public/scripts/carrusel.js";
---

<html lang="es">
  <head>
    <style is:global>
      @import "../styles/navbarStyle.css";
      @import "../styles/colores.css";
      @import "../styles/mainStyle.css";
      @import "../styles/introduccionStyle.css";
      @import "../styles/heroStyle.css";
      @import "../styles/descubreStyle.css";
      @import "../styles/impulsaStyle.css";
      @import "../styles/creceStyle.css";
      @import "../styles/formularioStyle.css";
      @import "../styles/contactoStyle.css";
      @import "../styles/carrusel.css";
    </style>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/barriohub-landing/favicon.svg"
    />
    <link rel="icon" href="/barriohub-landing/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Barrio Hub - Tu espacio en Chamartín</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <script type="module" src="/public/scripts/menu.js"></script>
    <script type="module" src="/public/scripts/carrusel.js"></script>
  </body>
</html>
